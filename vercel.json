{
    "version": 2,
    "functions": {
        "backend/app/main.py": {
            "runtime": "python@3.10"
        }
    },
    "rewrites": [
        {
            "source": "/api/v1/(.*)",
            "destination": "backend/app/main.py"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}